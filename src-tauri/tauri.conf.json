{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "ProjectFlow",
	"version": "0.1.0",
	"identifier": "com.projectflow.desktop",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:15173",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "ProjectFlow - 项目管理工具",
				"width": 1280,
				"height": 800,
				"minWidth": 1280,
				"minHeight": 800,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
